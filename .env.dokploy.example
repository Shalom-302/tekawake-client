# Variables du client Next.js.
#
# ⚠️ IMPORTANT : les NEXT_PUBLIC_* sont INLINÉES au BUILD (next build), pas lues
# au runtime. Dans Dokploy, elles sont passées en BUILD-ARGS par
# client/docker-compose.dokploy.yml (qui lit ces variables via ${VAR:-défaut}).
# Les renseigner dans l'onglet Environment de Dokploy AVANT le build.
# Changer une valeur ⇒ rebuild de l'image.

# --- Requis (pointage vers l'API déployée) ---
NEXT_PUBLIC_API_URL=https://veille-api.kortexai.dev/api
NEXT_PUBLIC_WS_URL=wss://veille-api.kortexai.dev/api

# --- Optionnels (flags ; défauts sains si absents) ---
# PWA activée par défaut ; "false" pour désactiver.
NEXT_PUBLIC_ENABLE_PWA=true
# Activer la PWA aussi en mode dev ("true").
# NEXT_PUBLIC_PWA_DEV=false
# Activer les analytics en dev ("true").
# NEXT_PUBLIC_ENABLE_DEV_ANALYTICS=false
